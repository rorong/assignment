<div class="container">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Organizations</h1>
    <% if can? :create, Organization %>
      <%= link_to "Create New Organization", new_organization_path, class: "btn btn-primary" %>
    <% end %>
  </div>

  <% if current_user.minor? %>
    <% if current_user.approved? %>
      <div class="alert alert-success mb-4">
        <i class="fas fa-check-circle me-2"></i>
        <strong>Parental Consent Approved:</strong> You can participate in organizations with your parent's permission.
      </div>
    <% elsif current_user.rejected? %>
      <div class="alert alert-danger mb-4">
        <i class="fas fa-times-circle me-2"></i>
        <strong>Parental Consent Rejected:</strong> Your parent/guardian has not approved your participation.
        <br><small>Contact support if you believe this is an error.</small>
      </div>
    <% else %>
      <div class="alert alert-warning mb-4">
        <i class="fas fa-clock me-2"></i>
        <strong>Parental Consent Pending:</strong> We've sent a consent request to your parent/guardian.
        <% if current_user.parent_email.present? %>
          <br><small><i class="fas fa-envelope me-1"></i>Consent email sent to: <%= current_user.parent_email %></small>
          <br><small>Please ask your parent/guardian to check their email and approve your account.</small>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <div class="row">
    <% @organizations.each do |organization| %>
      <div class="col-md-6 col-lg-4 mb-4">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title"><%= organization.name %></h5>
            <p class="card-text"><%= truncate(organization.description, length: 100) %></p>
            <p class="text-muted">
              <small>Admin: <%= organization.admin.first_name %> <%= organization.admin.last_name %></small>
            </p>
            <p class="text-muted">
              <small>Members: <%= organization.organization_memberships.approved.count %></small>
            </p>
            <%= link_to "View Details", organization, class: "btn btn-outline-primary" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <% if @organizations.empty? %>
    <div class="text-center mt-5">
      <h3>No organizations yet</h3>
      <p>Be the first to create an organization!</p>
      <% if can? :create, Organization %>
        <%= link_to "Create Organization", new_organization_path, class: "btn btn-primary" %>
      <% end %>
    </div>
  <% end %>
</div> 