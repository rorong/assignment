<div class="container">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <div class="card shadow-lg">
        <div class="card-header bg-success text-white text-center">
          <h4 class="mb-0">
            <i class="fas fa-user-plus me-2"></i>Create Account
          </h4>
        </div>
        <div class="card-body p-4">
          <%= form_for(resource, as: resource_name, url: registration_path(resource_name), local: true) do |f| %>
            <%= render "devise/shared/error_messages", resource: resource %>

            <div class="row">
              <div class="col-md-6 mb-3">
                <%= f.label :first_name, class: "form-label" %>
                <%= f.text_field :first_name, autofocus: true, class: "form-control" %>
              </div>
              <div class="col-md-6 mb-3">
                <%= f.label :last_name, class: "form-label" %>
                <%= f.text_field :last_name, class: "form-control" %>
              </div>
            </div>

            <div class="mb-3">
              <%= f.label :email, class: "form-label" %>
              <%= f.email_field :email, autocomplete: "email", class: "form-control" %>
            </div>

            <div class="mb-3">
              <%= f.label :birth_date, "Date of Birth", class: "form-label" %>
              <%= f.date_field :birth_date, class: "form-control", id: "birth_date" %>
              <div class="form-text">
                <i class="fas fa-info-circle me-1"></i>
                Users under 18 require parental consent
              </div>
            </div>

            <!-- Parental Consent Section -->
            <div id="parental-consent-section" class="mb-3" style="display: none;">
              <div class="alert alert-info">
                <h6><i class="fas fa-child me-2"></i>Parental Consent Required</h6>
                <p class="mb-2">Since you're under 18, we need parental consent for your registration.</p>
              </div>
              
              <div class="mb-3">
                <%= f.label :parent_email, "Parent/Guardian Email", class: "form-label" %>
                <%= f.email_field :parent_email, class: "form-control" %>
              </div>

              <div class="form-check">
                <%= f.check_box :parental_consent, class: "form-check-input" %>
                <%= f.label :parental_consent, "I have parental consent to create this account", class: "form-check-label" %>
              </div>
            </div>

            <div class="row">
              <div class="col-md-6 mb-3">
                <%= f.label :password, class: "form-label" %>
                <%= f.password_field :password, autocomplete: "new-password", class: "form-control" %>
                <% if @minimum_password_length %>
                  <div class="form-text">
                    Minimum <%= @minimum_password_length %> characters
                  </div>
                <% end %>
              </div>
              <div class="col-md-6 mb-3">
                <%= f.label :password_confirmation, class: "form-label" %>
                <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
              </div>
            </div>

            <div class="d-grid">
              <%= f.submit "Create Account", class: "btn btn-success btn-lg" %>
            </div>
          <% end %>
        </div>
        <div class="card-footer text-center bg-light">
          <div class="small">
            <%= render "devise/shared/links" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('turbo:load', function() {
  const birthDateInput = document.getElementById('birth_date');
  const parentalConsentSection = document.getElementById('parental-consent-section');
  
  function checkAge() {
    if (birthDateInput.value) {
      const birthDate = new Date(birthDateInput.value);
      const today = new Date();
      const age = Math.floor((today - birthDate) / (365.25 * 24 * 60 * 60 * 1000));
      
      if (age < 18) {
        parentalConsentSection.style.display = 'block';
      } else {
        parentalConsentSection.style.display = 'none';
      }
    }
  }
  
  if (birthDateInput) {
    birthDateInput.addEventListener('change', checkAge);
    checkAge(); // Check on page load
  }
});
</script>